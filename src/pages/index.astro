---
import { getCollection } from "astro:content";
import Polaroid from "../components/Polaroid.astro";
import Signature from "../components/Signature.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const VISIBLE = 3;

const work = (await getCollection("works")).sort((a, b) => a.data.order - b.data.order);
const words = (await getCollection("words")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const workVisible = work.slice(0, VISIBLE);
const workHidden = work.slice(VISIBLE);
const wordsVisible = words.slice(0, VISIBLE);
const wordsHidden = words.slice(VISIBLE);

const fmt = (d: Date) => d.toLocaleDateString("fr-FR", { month: "short", year: "numeric" });
const latest = work[0]?.data.date ?? new Date();
---

<BaseLayout title="Ely Delva" description="Design et écriture par Ely Delva.">
  <header class="site-header" style="--stagger: 0" data-motion>
    <Signature />
    <span class="updated">Mis à jour {fmt(latest)}</span>
  </header>

  <p class="bio" style="--stagger: 1" data-motion>
    Depuis dix ans, je développe et je fabrique des produits destinés à résoudre divers problèmes, certains plus utiles que d'autres.
  </p>

  <section class="entry-list" style="--stagger: 2" data-motion>
    <h2>Travaux</h2>
    {work.length === 0 && (
      <p class="entry-empty">Je reconstruis doucement cette étagère. De nouvelles pièces arrivent bientôt.</p>
    )}
    {
      workVisible.map((entry, i) => (
        <a href={`/works/${entry.id}`} class="entry-row" data-vt-collection="works" data-vt-slug={entry.id}>
          <Polaroid
            image={entry.data.image}
            stack={entry.data.stack}
            alt={entry.data.title}
            index={i}
          />
          <span class="entry-content">
            <span class="label">{entry.data.title}</span>
            <span class="meta">{fmt(entry.data.date)}</span>
          </span>
        </a>
      ))
    }
    {
      workHidden.length > 0 && (
        <a href="/works" class="entry-row">
          <Polaroid
            image={workHidden[0].data.image}
            stack={workHidden.slice(1, 3).map((e) => e.data.image)}
            alt="More works"
            index={workVisible.length}
          />
          <span class="entry-content">
            <span class="label">Plus</span>
            <span class="meta chevron">›</span>
          </span>
        </a>
      )
    }
  </section>

  <section class="entry-list" style="--stagger: 3" data-motion>
    <h2>Écrits</h2>
    {words.length === 0 && (
      <p class="entry-empty">Des brouillons mijotent. Rien à lire pour l'instant.</p>
    )}
    {
      wordsVisible.map((entry, i) => (
        <a
          href={`/words/${entry.id}`}
          class="entry-row"
          data-vt-collection="words"
          data-vt-slug={entry.id}
        >
          <Polaroid image={entry.data.image} alt={entry.data.title} index={i + 10} />
          <span class="entry-content">
            <span class="label">{entry.data.title}</span>
            <span class="meta">{fmt(entry.data.date)}</span>
          </span>
        </a>
      ))
    }
    {
      wordsHidden.length > 0 && (
        <a href="/words" class="entry-row">
          <Polaroid
            image={wordsHidden[0].data.image}
            stack={wordsHidden.slice(1, 3).map((e) => e.data.image)}
            alt="More words"
            index={wordsVisible.length + 10}
          />
          <span class="entry-content">
            <span class="label">Plus</span>
            <span class="meta chevron">›</span>
          </span>
        </a>
      )
    }
  </section>

  <section class="contact" style="--stagger: 4" data-motion>
    <h2>Contact</h2>
    <p class="contact-intro">Toujours partant pour discuter, de projets, d'idées, ou juste pour dire bonjour.</p>
    <ul class="contact-list">
      <li>
        <a href="mailto:ely.delva@outlook.com" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </a>
      </li>
      <li>
        <a href="tel:+33755610721" aria-label="Phone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/ely-delva/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45Z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://x.com/justelydelva" target="_blank" rel="noopener" aria-label="Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644Z"/></svg>
        </a>
      </li>
      <li>
        <a href="https://www.instagram.com/ely_delva" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/elydelva" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.1-1.47-1.1-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.5 9.5 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.85-2.34 4.7-4.57 4.94.36.31.68.92.68 1.85v2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"/></svg>
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
