---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Polaroid from "../../components/Polaroid.astro";

const work = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
const fmt = (d: Date) => d.toLocaleDateString("en", { month: "short", year: "numeric" });
---

<BaseLayout title="Work — Ely Delva">
  <header class="site-header" data-motion style="--stagger: 0">
    <a href="/" class="updated">← Back</a>
  </header>

  <section class="entry-list" data-motion style="--stagger: 1">
    <h2>work</h2>
    {work.length === 0 ? (
      <p class="entry-empty">
        Quietly rebuilding this shelf. New pieces soon — until then, you can peek at what I'm thinking about in <a href="/words">words</a>.
      </p>
    ) : (
      work.map((entry, i) => (
        <a
          href={`/work/${entry.id}`}
          class="entry-row"
          data-vt-collection="work"
          data-vt-slug={entry.id}
        >
          <Polaroid
            image={entry.data.image}
            stack={entry.data.stack}
            alt={entry.data.title}
            index={i}
          />
          <span class="label">{entry.data.title}</span>
          <span class="meta">{fmt(entry.data.date)}</span>
        </a>
      ))
    )}
  </section>
</BaseLayout>
