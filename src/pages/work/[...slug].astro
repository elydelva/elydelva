---
import { getCollection, render } from "astro:content";
import Year from "../../components/blocks/Year.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("work");
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const heroSrc =
  entry.data.heroImage ??
  entry.data.image.replace("w=240&h=160", "w=1000&h=600").replace("q=80", "q=72");
---


<script>
  function initMermaidZoom() {
    const svgs = document.querySelectorAll<SVGElement>(".entry-body svg.flowchart");
    if (!svgs.length) return;

    let overlay = document.querySelector<HTMLDivElement>(".mermaid-overlay");
    if (!overlay) {
      overlay = document.createElement("div");
      overlay.className = "mermaid-overlay";
      document.body.appendChild(overlay);
    }

    const close = () => {
      overlay!.classList.remove("open");
      document.removeEventListener("keydown", onKey);
    };

    const onKey = (e: KeyboardEvent) => {
      if (e.key === "Escape") close();
    };

    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) close();
    });

    svgs.forEach((svg) => {
      // Skip if already wrapped
      if (svg.parentElement?.classList.contains("mermaid-wrap")) return;

      // Wrap SVG
      const wrap = document.createElement("div");
      wrap.className = "mermaid-wrap";
      svg.parentElement!.insertBefore(wrap, svg);
      wrap.appendChild(svg);

      // Veil + expand button
      const veil = document.createElement("div");
      veil.className = "mermaid-veil";

      const btn = document.createElement("button");
      btn.className = "mermaid-expand-btn";
      btn.setAttribute("aria-label", "Expand diagram");
      btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
      </svg>`;

      veil.appendChild(btn);
      wrap.appendChild(veil);

      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const clone = svg.cloneNode(true) as SVGElement;
        clone.style.maxWidth = "";
        clone.setAttribute("width", "100%");
        overlay!.innerHTML = "";
        overlay!.appendChild(clone);
        overlay!.classList.add("open");
        document.addEventListener("keydown", onKey);
      });
    });
  }

  document.addEventListener("astro:page-load", initMermaidZoom);
  initMermaidZoom();
</script>

<BaseLayout
  title={`${entry.data.title} — Ely Delva`}
  description={entry.data.description}
  preloadImage={heroSrc}
  wide
>
  <article class="entry">
    <a href="/" data-back data-reveal class="back-button" aria-label="Back">
      <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M13 6 L8 11 L13 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </a>
    <figure class="figure figure--hero">
      <img
        src={heroSrc}
        alt={entry.data.title}
        class="figure__img"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        style="view-transition-name: hero;"
      />
    </figure>

    <h1 class="entry-title" data-reveal>{entry.data.title}</h1>
    <Year date={entry.data.date} />
    <div class="entry-body">
      <Content />
    </div>
  </article>
</BaseLayout>
