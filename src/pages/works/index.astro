---
import { getCollection } from "astro:content";
import Polaroid from "../../components/Polaroid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const work = (await getCollection("works")).sort((a, b) => a.data.order - b.data.order);
const fmt = (d: Date) => d.toLocaleDateString("fr-FR", { month: "short", year: "numeric" });
---

<BaseLayout title="Travaux — Ely Delva">
  <header class="site-header" data-motion style="--stagger: 0">
    <a href="/" class="updated">← Retour</a>
  </header>

  <section class="entry-list" data-motion style="--stagger: 1">
    <h2>Travaux</h2>
    {work.length === 0 ? (
      <p class="entry-empty">
        Je reconstruis doucement cette étagère. De nouvelles pièces arrivent bientôt — en attendant, vous pouvez jeter un œil à ce que je pense dans <a href="/words">écrits</a>.
      </p>
    ) : (
      work.map((entry, i) => (
        <a
          href={`/works/${entry.id}`}
          class="entry-row"
          data-vt-collection="works"
          data-vt-slug={entry.id}
        >
          <Polaroid
            image={entry.data.image}
            stack={entry.data.stack}
            alt={entry.data.title}
            index={i}
          />
          <span class="entry-content">
            <span class="label">{entry.data.title}</span>
            <span class="meta">{fmt(entry.data.date)}</span>
          </span>
        </a>
      ))
    )}
  </section>
</BaseLayout>
