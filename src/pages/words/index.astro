---
import { getCollection } from "astro:content";
import Polaroid from "../../components/Polaroid.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const words = (await getCollection("words")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const fmt = (d: Date) => d.toLocaleDateString("fr-FR", { month: "short", year: "numeric" });
---

<BaseLayout title="Écrits — Ely Delva">
  <header class="site-header" data-motion style="--stagger: 0">
    <a href="/" class="updated">← Retour</a>
  </header>

  <section class="entry-list" data-motion style="--stagger: 1">
    <h2>Écrits</h2>
    {words.length === 0 ? (
      <p class="entry-empty">
        Des brouillons mijotent. Rien à lire pour l'instant — revenez bientôt, ou allez voir les <a href="/works">travaux</a>.
      </p>
    ) : (
      words.map((entry, i) => (
        <a
          href={`/words/${entry.id}`}
          class="entry-row"
          data-vt-collection="words"
          data-vt-slug={entry.id}
        >
          <Polaroid image={entry.data.image} alt={entry.data.title} index={i} />
          <span class="entry-content">
            <span class="label">{entry.data.title}</span>
            <span class="meta">{fmt(entry.data.date)}</span>
          </span>
        </a>
      ))
    )}
  </section>
</BaseLayout>
